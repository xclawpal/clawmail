# ClawMail Configuration
# Copy this file to .env and fill in your values

# Backend API base URL (e.g. Cloudflare Workers endpoint)
VITE_API_HOST=https://api.example.workers.dev

# Bearer token for API authentication
VITE_API_KEY=replace-with-your-token

# Default email domain (without @)
VITE_MAIL_DOMAIN=example.com

# Inbox auto-poll interval in milliseconds
VITE_POLL_MS=8000

# UI theme: 'midnight' | 'paper'
VITE_THEME=midnight
